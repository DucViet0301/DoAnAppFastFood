<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="36dp"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="product"
            type="com.example.doanappfood.model.ProductDetailModel" />
    </data>

    <!--
        ROOT: RelativeLayout full screen, không fitsSystemWindows
        → ảnh sẽ vẽ dưới status bar, nút X/tim đè lên ảnh
    -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F5F5"
        android:fitsSystemWindows="false">

        <!-- ===== BOTTOM BAR CỐ ĐỊNH (khai báo trước để layout_above hoạt động) ===== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bottomBarContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            app:cardCornerRadius="0dp"
            app:cardElevation="16dp">

            <LinearLayout
                android:id="@+id/bottomBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingTop="10dp"
                android:paddingEnd="14dp"
                android:paddingBottom="24dp">

                <!-- Text tiết kiệm (chỉ hiện khi có sale) -->
                <TextView
                    android:id="@+id/tvsave"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="start"
                    android:textStyle="bold"
                    android:text="Bạn tiết kiêm được 14000 sau khi giảm giá"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    />

                <!-- Row: giảm/tăng + nút thêm giỏ hàng -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp"
                    android:orientation="horizontal">

                    <!-- Nút giảm -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDecrease"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        android:text="−"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/do_nhat"
                        android:textSize="22sp"
                        app:backgroundTint="@android:color/transparent"
                        app:cornerRadius="10dp"
                        app:strokeWidth="1.5dp" />

                    <!-- Số lượng -->
                    <TextView
                        android:id="@+id/tvQuantity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="4dp"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="@color/black"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <!-- Nút tăng -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnIncrease"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        android:text="+"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/do_nhat"
                        android:textSize="22sp"
                        app:backgroundTint="@android:color/transparent"
                        app:cornerRadius="10dp"
                        app:strokeWidth="1.5dp" />

                    <!-- Nút thêm giỏ hàng -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddToCart"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/do_tuoi"
                        app:cornerRadius="10dp"
                        tools:text="Thêm giỏ hàng: 59.000 đ" />

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== SCROLLABLE CONTENT (above bottom bar) ===== -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/nestedScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@id/bottomBarContainer"
            android:overScrollMode="never"
            android:fillViewport="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ===== ẢNH HERO + NÚT X/TIM ĐÈ LÊN ===== -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="300dp">

                    <!-- Ảnh sản phẩm, full fill -->
                    <ImageView
                        android:id="@+id/ivHeroBanner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:background="#FFFFFF"
                        tools:src="@tools:sample/backgrounds/scenic" />

                    <ImageView
                        android:id="@+id/ivback"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="start|top"
                        android:layout_marginStart="8dp"
                        android:layout_marginTop="8dp"

                        android:padding="8dp"
                        android:src="@drawable/ic_close"
                        android:background="@drawable/shape_back_button_bg"
                        android:elevation="6dp" />

                </FrameLayout>

                <!-- ===== CARD THÔNG TIN SẢN PHẨM ===== -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="0dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#FFFFFF"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Tên sản phẩm + giá -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvComboTitle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="sans-serif-medium"
                                android:text="Combo A"
                                android:textColor="#1A1A1A"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:layout_marginEnd="12dp" />

                            <!-- Giá sale + giá gốc gạch -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvPrice"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="59.000 đ"
                                    android:textColor="#E8192C"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />

                                <!-- Giá gốc bị gạch (ẩn khi không có sale) -->
                                <LinearLayout
                                    android:id="@+id/layoutOriginalPrice"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:visibility="gone">

                                    <ImageView
                                        android:layout_width="14dp"
                                        android:layout_height="14dp"
                                        android:layout_marginEnd="3dp"
                                        android:src="@drawable/tag"
                                        app:tint="@color/do_tuoi" />

                                    <TextView
                                        android:id="@+id/tvOriginalPrice"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="73.000 đ"
                                        android:textColor="#AAAAAA"
                                        android:textSize="13sp" />

                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="12dp"
                            android:background="#F0F0F0" />

                        <!-- Danh sách món trong combo -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvComboItems"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Spacer -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:background="#F5F5F5" />

                <!-- ===== CARD THÊM SỐT (ẩn nếu không có data) ===== -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSauces"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:cardCornerRadius="0dp"
                    app:cardElevation="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#FFFFFF"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingStart="20dp"
                            android:paddingTop="16dp"
                            android:paddingEnd="20dp"
                            android:paddingBottom="4dp"
                            android:text="Thêm sốt gà"
                            android:textColor="@color/black"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvSauces"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:padding="8dp" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>


            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </RelativeLayout>
</layout>