<?xml version="1.0" encoding="utf-8"?>
<!-- layout/activity_order_detail.xml -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:paddingTop="20dp"
        app:elevation="2dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/baseline_arrow_back_ios_24"

            app:title="Chi tiết đơn hàng">
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Nội dung cuộn -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="12dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <!-- Tiêu đề -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="14dp"
                        android:paddingTop="14dp"
                        android:text="Thông tin khách hàng"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Avatar + Tên + SĐT -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <!-- Avatar initials -->
                        <ImageView
                            android:id="@+id/tvAvatar"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginEnd="12dp"
                            android:gravity="center"

                            android:src="@drawable/avatar" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- Tên khách hàng — set từ order.customerName -->
                            <TextView
                                android:id="@+id/tvCustomerName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#1A1A1A"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                tools:text="Lê Hùng" />

                            <!-- Số điện thoại — set từ order.phoneNumber -->
                            <TextView
                                android:id="@+id/tvPhoneNumber"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:textColor="#888888"
                                android:textSize="12sp"
                                tools:text="0912 345 678" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#EEEEEE" />

                    <!-- Địa chỉ giao hàng -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingLeft="14dp"
                        android:paddingTop="0dp"
                        android:paddingRight="14dp"
                        android:paddingBottom="14dp">

                        <ImageView
                            android:layout_width="13dp"
                            android:layout_height="13dp"
                            android:layout_marginTop="2dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/locationstore" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Địa chỉ giao hàng"
                                android:textColor="#888888"
                                android:textSize="11sp" />

                            <!-- Địa chỉ giao — set từ order.deliveryAddress -->
                            <TextView
                                android:id="@+id/tvDeliveryAddress"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:lineSpacingExtra="2dp"
                                android:textColor="#333333"
                                android:textSize="13sp"
                                tools:text="55 Giải Phóng, Hai Bà Trưng, Hà Nội" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══════════════════════════════
                 CARD 2: Thông tin đơn hàng
            ═══════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Header -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.08"
                        android:paddingHorizontal="14dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="10dp"
                        android:text="THÔNG TIN ĐƠN HÀNG"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#EEEEEE" />

                    <!-- Mã đơn hàng -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="13dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="10dp"
                            android:src="@drawable/ic_receipt" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Mã đơn hàng"
                            android:textColor="@color/black"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvOrderId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#1A1A1A"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="#Order-101942" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginHorizontal="14dp"
                        android:background="#EEEEEE" />

                    <!-- Thời gian đặt -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="13dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="10dp"
                            android:src="@drawable/ic_calendar" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Thời gian đặt"
                            android:textColor="@color/black"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvOrderTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#1A1A1A"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="16/09/2024  15:30" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginHorizontal="14dp"
                        android:background="#EEEEEE" />

                    <!-- Cửa hàng -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="13dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="10dp"
                            android:src="@drawable/locationstore" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cửa hàng"
                            android:textColor="@color/black"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvStoreName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:textColor="#1A1A1A"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="Trần Đại Nghĩa, Bạch Mai, Hà Nội" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginHorizontal="14dp"
                        android:background="#EEEEEE" />

                    <!-- Trạng thái -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="13dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="10dp"
                            android:src="@drawable/ic_time" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Trạng thái"
                            android:textColor="@color/black"
                            android:textSize="13sp" />

                        <!-- Badge trạng thái -->
                        <TextView
                            android:id="@+id/tvStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_history"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:text="Đang xử lý"
                            android:textColor="#3C52B1"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

                        <!-- ═══════════════════════════════
                             CARD 3: Danh sách sản phẩm
                        ═══════════════════════════════ -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="#FFFFFF">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <!-- Header: Danh sách sp + tổng số lượng -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:paddingHorizontal="14dp"
                                    android:paddingVertical="10dp"
                                    android:background="#F9F9F9">

                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Danh sách sản phẩm"
                                        android:textColor="#1A1A1A"
                                        android:textSize="13sp"
                                        android:textStyle="bold" />

                                    <!-- Tổng số lượng — set động -->
                                    <TextView
                                        android:id="@+id/tvTotalItemCount"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="#888888"
                                        android:textSize="12sp"
                                        tools:text="4 sản phẩm" />
                                </LinearLayout>

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="0.5dp"
                                    android:background="#EEEEEE" />

                                <!-- ★ DYNAMIC: inflate item_product_row.xml vào đây -->
                                <LinearLayout
                                    android:id="@+id/llProductList"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical" />
                                <androidx.recyclerview.widget.RecyclerView
                                    android:id="@+id/rvProductList"
                                    android:paddingLeft="8dp"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"/>

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="0.5dp"
                                    android:background="#8C8C8C" />

                                <!-- Ghi chú đơn hàng -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:paddingHorizontal="14dp"
                                    android:paddingVertical="12dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Ghi chú"
                                        android:textColor="@color/black"
                                        android:textSize="13sp"
                                        android:textStyle="bold"
                                        android:layout_marginBottom="8dp" />

                                    <!-- Lấy dụng cụ ăn uống -->
                                    <TextView
                                        android:id="@+id/tvNoteUtensils"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="- Lấy dụng cụ ăn uống"
                                        android:textColor="#333333"
                                        android:textSize="13sp"
                                        android:layout_marginBottom="4dp" />

                                    <!-- Lấy tương ớt -->
                                    <TextView
                                        android:id="@+id/tvNoteChili"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="- Lấy tương ớt"
                                        android:textColor="#333333"
                                        android:textSize="13sp"
                                        android:layout_marginBottom="4dp" />

                                    <!-- Lấy tương cà -->
                                    <TextView
                                        android:id="@+id/tvNoteKetchup"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="- Lấy tương cà"
                                        android:textColor="#333333"
                                        android:textSize="13sp"
                                        android:layout_marginBottom="4dp" />

                                    <!-- Ghi chú chi tiết -->
                                    <TextView
                                        android:id="@+id/tvNoteDetail"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="#333333"
                                        android:textSize="13sp"
                                        android:lineSpacingExtra="2dp"
                                        tools:text="- Ít đá, không hành" />

                                </LinearLayout>

                                <!-- Đường kẻ nét đứt -->
                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="0.7dp"
                                    android:background="#000000"
                                    android:layout_marginHorizontal="14dp"
                                    android:layout_marginTop="4dp" />

                                <!-- Tổng tiền -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:paddingHorizontal="14dp"
                                    android:paddingVertical="12dp">

                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Tổng tiền"
                                        android:textColor="#1A1A1A"
                                        android:textSize="14sp"
                                        android:textStyle="bold" />

                                    <!-- Tổng tiền — set từ order.totalPrice -->
                                    <TextView
                                        android:id="@+id/tvTotalPrice"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="#A32D2D"
                                        android:textSize="18sp"
                                        android:textStyle="bold"
                                        tools:text="263.000 đ" />
                                </LinearLayout>

                                <!-- Nút huỷ đơn hàng -->
                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnCancelOrder"
                                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                    android:layout_width="match_parent"
                                    android:layout_height="48dp"
                                    android:layout_marginHorizontal="14dp"
                                    android:layout_marginBottom="14dp"
                                    android:text="Huỷ đơn hàng"
                                    android:textColor="#A32D2D"
                                    android:textSize="14sp"
                                    app:cornerRadius="10dp"
                                    app:strokeColor="#E24B4A"
                                    app:strokeWidth="1.5dp"
                                    app:backgroundTint="@android:color/transparent" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>